<% layout("/layouts/boilerplate") %>

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 col-xl-8">
            <h3 class="mt-4 mb-4"><b><%= listing.title %></b></h3>
            
            <div class="row">
                <div class="col-12 col-md-6 mb-4">
                    <div class="card">
                        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing image">
                    </div>
                </div>
                
                <div class="col-12 col-md-6 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <p class="card-text"><b>Owned by:</b> <i><%= listing.owner ? listing.owner.username : 'Unknown' %></i></p>
                            <p class="card-text"><b>Description:</b> <%= listing.description %></p>
                            <p class="card-text"><b>Price:</b> <span id="listing-price">&dollar;<%= listing.price.toLocaleString('en-US') %></span> per night <i class="tax-info" style="font-size: 0.9em; color: #717171; display: none;">+18% GST</i></p>
                            <p class="card-text"><b>Location:</b> <%= listing.country %>, <%= listing.location %></p>
                            
                            <!-- GST Toggle -->
                            <div class="form-check form-switch mt-3">
                                <input class="form-check-input" type="checkbox" id="gstToggle">
                                <label class="form-check-label" for="gstToggle">Display Total Price (incl. GST)</label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>
                        <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline">
                            <button class="btn btn-danger delete-listing-btn">Delete</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- reveiws -->
            <div class="mt-4">
                <hr>
                <h4>Write a Review</h4>

                <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">

                    <div class="mb-3 mt-3">
                        <label for="rating" class="form-label">Rating</label>
                        <fieldset class="starability-slot">


                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                                checked aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>
                    <div class="mb-3 mt-3">
                        <label for="Comments" class="form-label"> Comments </label>
                        <textarea type="text" id="comments" name="review[comments]" cols="5" rows="5"
                            class="form-control"></textarea>
                        <div class="invalid-feedback">Please Submit valid review</div>
                    </div>
                    <br>
                    <button class="btn btn-outline-dark">Submit Review</button>
                </form>

            </div>

            <hr>
            <!-- reviews -->
            <h4 class="mt-4">Reviews</h4>
            <% if(listing.reviews && listing.reviews.length> 0) { %>
                <% for(let review of listing.reviews) { %>
                    <div class="card mt-3">
                        <div class="card-body">
                            <p class="card-title">By: <b>@<%= review.author ? review.author.username : 'Deleted User' %>
                                </b></p>
                            <p class="starability-result card-text" data-rating="<%= review.rating %>">
                                Rated: <%= review.rating %> stars
                            </p>

                            <p class="card-text">
                                <%= review.comments %>
                            </p>
                            <p class="card-text"><small class="text-muted">Posted on <%= new
                                        Date(review.createdAt).toLocaleDateString() %></small></p>

                        </div>
                        <!-- to delete the review -->
                        <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                            method="POST" class="mb-3 ms-3">
                            <button class="btn-sm btn btn-danger">Delete</button>
                        </form>
                    </div>
                    <% } %>
                        <% } else { %>
                            <p class="text-muted">No reviews yet. Be the first to write a review!</p>
                            <% } %>

            <!-- Map Section -->
            <div class="mt-5 mb-5">
                <h4>Where you'll be</h4>
                <div id="map"></div>
            </div>
        </div>
    </div>
</div>

    <script src="/js/show.js"></script>
    <script>
        // Initialize the show page with data from the template
        initShowPage("<%= process.env.MAPTILER_KEY %>", <%- JSON.stringify(listing) %>);
    </script>
    <script src="/js/map.js"></script>