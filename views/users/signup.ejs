<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/CSS/forms.css">

<div class="auth-form-container">
    <div class="auth-form-card card">
        <div class="auth-form-body">
            <h1 class="auth-form-title">Sign Up</h1>
            <form action="/signup" method="POST" class="needs-validation" novalidate>
                <div class="mb-4">
                    <label for="username" class="form-label auth-form-label">Username</label>
                    <input name="username" type="text" placeholder="Choose a username" class="form-control auth-form-input" id="username" required>
                    <div class="valid-feedback">Username Looks Good</div>
                </div>
                <div class="mb-4">
                    <label for="email" class="form-label auth-form-label">Email</label>
                    <input name="email" type="email" placeholder="Enter your email" class="form-control auth-form-input" id="email" required>
                    <div class="valid-feedback">Email Looks Good</div>
                </div>
                <div class="mb-4">
                    <label for="password" class="form-label auth-form-label">Password</label>
                    <input name="password" type="password" placeholder="Create a password" class="form-control auth-form-input" id="password" required>
                    <div class="valid-feedback">Password Looks Good</div>
                </div>
                <button type="submit" class="btn btn-primary auth-form-btn">Sign Up</button>
            </form>
            <div class="auth-form-footer">
                <p>Already have an account? <a href="/login" class="btn btn-outline-success auth-form-link">Log In</a></p>
            </div>
        </div>
    </div>
</div>