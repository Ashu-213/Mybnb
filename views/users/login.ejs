<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/CSS/forms.css">

<div class="auth-form-container">
    <div class="auth-form-card card">
        <div class="auth-form-body">
            <h1 class="auth-form-title">Log In</h1>
            <form action="/login" method="POST">
                <div class="mb-4">
                    <label for="username" class="form-label auth-form-label">Username</label>
                    <input name="username" type="text" placeholder="Enter your username" class="form-control auth-form-input" id="username" required>
                </div>
                <div class="mb-4">
                    <label for="password" class="form-label auth-form-label">Password</label>
                    <input name="password" type="password" placeholder="Enter your password" class="form-control auth-form-input" id="password" required>
                </div>
                <button type="submit" class="btn btn-primary auth-form-btn">Log In</button>
            </form>
            <div class="auth-form-footer">
                <p>Don't have an account? <a href="/signup" class="btn btn-outline-success auth-form-link">Sign Up</a></p>
            </div>
        </div>
    </div>
</div>